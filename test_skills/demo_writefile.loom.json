{
  "schema_version": "v1",
  "skill_id": "demo_writefile",
  "description": "Write a literal 'hi' into out/hello.txt inside the sandbox. Minimum-viable v1 write demonstrator.",
  "parameters": {
    "msg": {"type": "string", "default_value": "hi", "required": false}
  },
  "execution_dag": [
    {
      "step_id": "s1",
      "kind": "write_file",
      "args": {"path": "out/hello.txt", "content": "hi"},
      "inputs": {"msg": "${msg}"},
      "outputs": []
    }
  ],
  "capabilities": [
    {"kind": "vfs.write", "scope": "out/"}
  ]
}
