# Port the MCP sidecar listens on (default: 8080)
LOOM_PORT=8080

# Draft policy for migrated skills: refuse | warn | allow (default: warn)
LOOM_DRAFT_POLICY=warn

# Anthropic API key — only needed for LLM-assisted migration
# Leave empty to disable LLM; non-mechanical skills become stubs
ANTHROPIC_API_KEY=
